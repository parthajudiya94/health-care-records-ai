# === App ===
# Public URL in production (HTTPS) for absolute links; optional locally
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Database (MySQL) ===
# Use TLS in production. Example: mysql://user:pass@host:3306/db?sslaccept=strict
# Ensure host volume encryption, backups, and a BAA where you handle ePHI.
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/health_care_ai

# === Auth ===
# Long random string (e.g. openssl rand -base64 48). Rotate with a runbook in prod.
JWT_SECRET=

# Optional: used only by `npx prisma db seed` to upsert an ADMIN user (dev/staging).
# Do not use weak passwords in production.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# === AI: OpenAI (BAA with vendor required before sending real PHI) ===
OPENAI_API_KEY=
# Default https://api.openai.com — override for proxies or private gateways only.
#OPENAI_BASE_URL=https://api.openai.com
# Model id (examples): gpt-4o-mini, gpt-4.1-mini, gpt-4o
AI_MODEL=gpt-4o-mini
#OPENAI_MAX_TOKENS=1200
# Set to false to skip external API calls and store only extraction errors in summary.
AI_PROCESSING_ENABLED=true

# === Compliance checklist (org-level, not automatic) ===
# - BAA: hosting, DB, backups, object storage, error tracking, and any model API that processes report text
# - Encryption: TLS in transit, encrypted disks/storage
# - Audit: use AuditLog + avoid logging PHI in application logs
